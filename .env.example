# Environment Variables Template — copy to .env.local and fill in your values

# Last.fm API (free at https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_lastfm_api_key

# Supabase (free at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Gemini AI (free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Resonix
